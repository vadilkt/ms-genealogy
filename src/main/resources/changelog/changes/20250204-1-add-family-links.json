{
  "databaseChangeLog": [
    {
      "changeSet": {
        "id": "2025-02-04-01",
        "author": "Vadil K.",
        "comment": "Add father_id and mother_id to profile for parent-child links",
        "changes": [
          {
            "addColumn": {
              "tableName": "profile",
              "columns": [
                {
                  "column": {
                    "name": "father_id",
                    "type": "bigint",
                    "constraints": {
                      "nullable": true,
                      "foreignKeyName": "fk_profile_father",
                      "references": "profile(id)"
                    }
                  }
                },
                {
                  "column": {
                    "name": "mother_id",
                    "type": "bigint",
                    "constraints": {
                      "nullable": true,
                      "foreignKeyName": "fk_profile_mother",
                      "references": "profile(id)"
                    }
                  }
                }
              ]
            }
          }
        ]
      }
    },
    {
      "changeSet": {
        "id": "2025-02-04-02",
        "author": "Vadil K.",
        "comment": "Create marriage table: one husband can have several wives, one wife only one husband",
        "changes": [
          {
            "createTable": {
              "tableName": "marriage",
              "columns": [
                {
                  "column": {
                    "name": "id",
                    "type": "bigint",
                    "autoIncrement": true,
                    "constraints": {
                      "primaryKey": true,
                      "nullable": false
                    }
                  }
                },
                {
                  "column": {
                    "name": "husband_id",
                    "type": "bigint",
                    "constraints": {
                      "nullable": false,
                      "foreignKeyName": "fk_marriage_husband",
                      "references": "profile(id)"
                    }
                  }
                },
                {
                  "column": {
                    "name": "wife_id",
                    "type": "bigint",
                    "constraints": {
                      "nullable": false,
                      "unique": true,
                      "foreignKeyName": "fk_marriage_wife",
                      "references": "profile(id)"
                    }
                  }
                },
                {
                  "column": {
                    "name": "marriage_date",
                    "type": "TIMESTAMP WITH TIME ZONE"
                  }
                },
                {
                  "column": {
                    "name": "end_date",
                    "type": "TIMESTAMP WITH TIME ZONE"
                  }
                }
              ]
            }
          }
        ]
      }
    }
  ]
}
