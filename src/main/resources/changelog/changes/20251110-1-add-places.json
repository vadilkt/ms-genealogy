{
  "databaseChangeLog": [
    {
      "changeSet": {
        "id": "2025-02-10-01",
        "author": "Vadil K.",
        "comment": "Create place table for birth/death locations",
        "changes": [
          {
            "createTable": {
              "tableName": "place",
              "columns": [
                {
                  "column": {
                    "name": "id",
                    "type": "bigint",
                    "autoIncrement": true,
                    "constraints": {
                      "primaryKey": true,
                      "nullable": false
                    }
                  }
                },
                {
                  "column": {
                    "name": "city",
                    "type": "VARCHAR(255)",
                    "constraints": {
                      "nullable": false
                    }
                  }
                },
                {
                  "column": {
                    "name": "country",
                    "type": "VARCHAR(255)",
                    "constraints": {
                      "nullable": false
                    }
                  }
                },
                {
                  "column": {
                    "name": "region",
                    "type": "VARCHAR(255)"
                  }
                }
              ]
            }
          }
        ]
      }
    },
    {
      "changeSet": {
        "id": "2025-02-10-02",
        "author": "Vadil K.",
        "comment": "Add birth_place_id and death_place_id to profile",
        "changes": [
          {
            "addColumn": {
              "tableName": "profile",
              "columns": [
                {
                  "column": {
                    "name": "birth_place_id",
                    "type": "bigint",
                    "constraints": {
                      "nullable": true,
                      "foreignKeyName": "fk_profile_birth_place",
                      "references": "place(id)"
                    }
                  }
                },
                {
                  "column": {
                    "name": "death_place_id",
                    "type": "bigint",
                    "constraints": {
                      "nullable": true,
                      "foreignKeyName": "fk_profile_death_place",
                      "references": "place(id)"
                    }
                  }
                }
              ]
            }
          }
        ]
      }
    }
  ]
}
