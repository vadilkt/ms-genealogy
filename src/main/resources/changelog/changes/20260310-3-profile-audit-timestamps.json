{
  "databaseChangeLog": [
    {
      "changeSet": {
        "id": "2026-03-10-03",
        "author": "Vadil K.",
        "comment": "Add createdAt and updatedAt audit columns to profile table.",
        "changes": [
          {
            "addColumn": {
              "tableName": "profile",
              "columns": [
                {
                  "column": {
                    "name": "created_at",
                    "type": "TIMESTAMP WITH TIME ZONE",
                    "defaultValueComputed": "NOW()",
                    "constraints": { "nullable": false }
                  }
                },
                {
                  "column": {
                    "name": "updated_at",
                    "type": "TIMESTAMP WITH TIME ZONE",
                    "defaultValueComputed": "NOW()",
                    "constraints": { "nullable": false }
                  }
                }
              ]
            }
          }
        ]
      }
    }
  ]
}
