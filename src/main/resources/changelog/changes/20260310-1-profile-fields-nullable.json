{
  "databaseChangeLog": [
    {
      "changeSet": {
        "id": "2026-03-10-01",
        "author": "Vadil K.",
        "comment": "Make profile required fields nullable to support auto-created empty profiles on registration.",
        "changes": [
          {
            "dropNotNullConstraint": {
              "tableName": "profile",
              "columnName": "first_name",
              "columnDataType": "VARCHAR(255)"
            }
          },
          {
            "dropNotNullConstraint": {
              "tableName": "profile",
              "columnName": "gender",
              "columnDataType": "VARCHAR(50)"
            }
          },
          {
            "dropNotNullConstraint": {
              "tableName": "profile",
              "columnName": "date_of_birth",
              "columnDataType": "TIMESTAMP WITH TIME ZONE"
            }
          },
          {
            "dropNotNullConstraint": {
              "tableName": "profile",
              "columnName": "residence",
              "columnDataType": "VARCHAR(255)"
            }
          }
        ]
      }
    }
  ]
}
