{
  "databaseChangeLog": [
    {
      "changeSet": {
        "id": "2026-03-10-04",
        "author": "Vadil K.",
        "comment": "Create notifications table for in-app user notifications.",
        "changes": [
          {
            "createTable": {
              "tableName": "notification",
              "columns": [
                {
                  "column": {
                    "name": "id",
                    "type": "bigint",
                    "autoIncrement": true,
                    "constraints": { "primaryKey": true, "nullable": false }
                  }
                },
                {
                  "column": {
                    "name": "user_id",
                    "type": "bigint",
                    "constraints": {
                      "nullable": false,
                      "foreignKeyName": "fk_notification_user",
                      "references": "users(id)"
                    }
                  }
                },
                {
                  "column": {
                    "name": "message",
                    "type": "TEXT",
                    "constraints": { "nullable": false }
                  }
                },
                {
                  "column": {
                    "name": "read",
                    "type": "boolean",
                    "defaultValueBoolean": false,
                    "constraints": { "nullable": false }
                  }
                },
                {
                  "column": {
                    "name": "created_at",
                    "type": "TIMESTAMP WITH TIME ZONE",
                    "defaultValueComputed": "NOW()",
                    "constraints": { "nullable": false }
                  }
                }
              ]
            }
          }
        ]
      }
    }
  ]
}
