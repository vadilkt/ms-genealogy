# Copie ce fichier en .env et remplis les valeurs

# Base de données PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/genealogie
USER_NAME=postgres
DB_PASSWORD=change_me

# JWT — doit faire au moins 64 caractères
# Générer avec : openssl rand -base64 64
CLIENT_JWT_SECRET=change_me_with_a_very_long_secret_of_at_least_64_characters_minimum
JWT_TOKEN_VALIDITY=86400000
