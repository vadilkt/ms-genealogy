{
  "databaseChangeLog": [
    {
      "changeSet": {
        "id": "2025-10-07-03",
        "author": "Vadil K.",
        "comment": "Create a professional_profile table with foreign key to profile",
        "changes": [
          {
            "createTable": {
              "tableName": "professional_profile",
              "columns": [
                {
                  "column": {
                    "name": "id",
                    "type": "bigint",
                    "autoIncrement": true,
                    "constraints": {
                      "primaryKey": true,
                      "nullable": false
                    }
                  }
                },
                {
                  "column": {
                    "name": "profile_id",
                    "type": "bigint",
                    "constraints": {
                      "nullable": false,
                      "foreignKeyName": "fk_professional_profile_profile",
                      "references": "profile(id)"
                    }
                  }
                },
                {
                  "column": {
                    "name": "profession",
                    "type": "VARCHAR(255)",
                    "constraints": {
                      "nullable": false
                    }
                  }
                },
                {
                  "column": {
                    "name": "entreprise",
                    "type": "VARCHAR(255)",
                    "constraints": {
                      "nullable": false
                    }
                  }
                },
                {
                  "column": {
                    "name": "ville",
                    "type": "VARCHAR(255)",
                    "constraints": {
                      "nullable": false
                    }
                  }
                },
                {
                  "column": {
                    "name": "date_debut",
                    "type": "TIMESTAMP WITH TIME ZONE",
                    "constraints": {
                      "nullable": false
                    }
                  }
                },
                {
                  "column": {
                    "name": "date_fin",
                    "type": "TIMESTAMP WITH TIME ZONE"
                  }
                },
                {
                  "column": {
                    "name": "description",
                    "type": "VARCHAR(1000)"
                  }
                }
              ]
            }
          }
        ]
      }
    }
  ]
}