{
  "databaseChangeLog": [
    {
      "changeSet": {
        "id": "2025-10-07",
        "author": "Vadil K.",
        "comment": "Create a profile table with foreign key to user",
        "changes": [
          {
            "createTable": {
              "tableName": "profile",
              "columns": [
                {
                  "column": {
                    "name": "id",
                    "type": "bigint",
                    "autoIncrement": true,
                    "constraints": {
                      "primaryKey": true,
                      "nullable": false
                    }
                  }
                },
                {
                  "column": {
                    "name": "user_id",
                    "type": "bigint",
                    "constraints": {
                      "nullable": false,
                      "unique": true,
                      "foreignKeyName": "fk_profile_user",
                      "references": "users(id)"
                    }
                  }
                },
                {
                  "column": {
                    "name": "first_name",
                    "type": "VARCHAR(255)",
                    "constraints": {
                      "nullable": false
                    }
                  }
                },
                {
                  "column": {
                    "name": "last_name",
                    "type": "VARCHAR(255)"
                  }
                },
                {
                  "column": {
                    "name": "gender",
                    "type": "VARCHAR(50)",
                    "constraints": {
                      "nullable": false
                    }
                  }
                },
                {
                  "column": {
                    "name": "date_of_birth",
                    "type": "TIMESTAMP WITH TIME ZONE",
                    "constraints": {
                      "nullable": false
                    }
                  }
                },
                {
                  "column": {
                    "name": "date_of_death",
                    "type": "TIMESTAMP WITH TIME ZONE"
                  }
                },
                {
                  "column": {
                    "name": "residence",
                    "type": "VARCHAR(255)",
                    "constraints": {
                      "nullable": false
                    }
                  }
                }
              ]
            }
          }
        ]
      }
    }
  ]
}